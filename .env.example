# ======================================
# Gold Monitor 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ======================================

# ---- AI 提供商 API Key ----
# 通义千问（阿里云 DashScope）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI（可选，备用）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Webhook 通知 ----
# 飞书 Webhook 地址
FEISHU_WEBHOOK_URL=

# 企业微信 Webhook 地址
WECOM_WEBHOOK_URL=

# 钉钉 Webhook 地址（含 access_token）
DINGTALK_WEBHOOK_URL=

# ---- 金价 API ----
# 金价数据 API Key（可选，部分免费 API 不需要）
GOLD_API_KEY=

# ---- hellocola-gateway 网关 ----
# 网关地址（启用 gateway.enabled 后生效，Docker 环境用 host.docker.internal）
GATEWAY_URL=http://host.docker.internal:3000
# 本服务的外部可访问地址（网关反向代理目标，应为宿主机可达地址）
GATEWAY_TARGET=http://host.docker.internal:5051
